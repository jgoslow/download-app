{
  "name": "hex-app",
  "version": "0.7.1",
  "description": "Release metadata + changelog automation for the Basn macOS app.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "release": "cd tools && bun run build",
    "changeset": "changeset",
    "changeset:add": "changeset",
    "changeset:add-ai": "bun run tools/scripts/add-changeset.ts",
    "changeset:status": "changeset status --verbose",
    "changeset:version": "changeset version",
    "sync-changelog": "bun run tools/scripts/sync-changelog.ts",
    "archive-to-fixture": "bun run tools/scripts/archive-to-fixture.ts",
    "capture-grades": "bun run tools/scripts/capture-grades.ts"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8"
  }
}
