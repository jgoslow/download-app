{
  "id": "google",
  "name": "Google",
  "icon": "globe",
  "auth": {
    "methods": ["oauth"],
    "oauth_provider": "google",
    "scopes_selectable": true,
    "available_scopes": {
      "calendar": {
        "label": "Calendar access",
        "scope": "https://www.googleapis.com/auth/calendar",
        "default": true
      },
      "gmail": {
        "label": "Email (Gmail) access",
        "scope": "https://www.googleapis.com/auth/gmail.send",
        "default": true
      },
      "docs": {
        "label": "Docs access",
        "scope": "https://www.googleapis.com/auth/documents",
        "default": true
      },
      "drive_file": {
        "label": "Drive file access",
        "scope": "https://www.googleapis.com/auth/drive.file",
        "default": true
      }
    }
  },
  "base_url": {
    "oauth": "https://www.googleapis.com"
  },
  "discovery": {
    "calendars": {
      "endpoint": "{base_url}/calendar/v3/users/me/calendarList",
      "method": "GET",
      "extract": "$.items[*].{id, summary}",
      "description": "User's calendars",
      "refresh_interval_hours": 168
    }
  },
  "actions": {
    "create_event": {
      "display_name": "Create calendar event",
      "description": "Create an event in Google Calendar",
      "endpoint": "{base_url}/calendar/v3/calendars/primary/events",
      "method": "POST",
      "headers": {
        "Content-Type": "application/json"
      },
      "body_template": {
        "summary": "{summary}",
        "description": "{description}",
        "start": {
          "dateTime": "{start_time}"
        },
        "end": {
          "dateTime": "{end_time}"
        }
      },
      "parameters": {
        "summary": {
          "type": "string",
          "required": true,
          "description": "Event title"
        },
        "description": {
          "type": "string",
          "required": false,
          "description": "Event description"
        },
        "start_time": {
          "type": "string",
          "required": true,
          "description": "Start time in ISO 8601 format"
        },
        "end_time": {
          "type": "string",
          "required": true,
          "description": "End time in ISO 8601 format"
        }
      },
      "success_extract": "$.id",
      "success_message": "Event created"
    },
    "send_email": {
      "display_name": "Send email",
      "description": "Send an email via Gmail",
      "endpoint": "{base_url}/gmail/v1/users/me/messages/send",
      "method": "POST",
      "special_handler": "gmail_send",
      "parameters": {
        "to": {
          "type": "string",
          "required": true,
          "description": "Recipient email address"
        },
        "subject": {
          "type": "string",
          "required": true,
          "description": "Email subject line"
        },
        "body": {
          "type": "string",
          "required": true,
          "description": "Email body text"
        }
      },
      "success_extract": "$.id",
      "success_message": "Email sent"
    },
    "create_document": {
      "display_name": "Create Google Doc",
      "description": "Create a new Google Docs document",
      "endpoint": "https://docs.googleapis.com/v1/documents",
      "method": "POST",
      "headers": {
        "Content-Type": "application/json"
      },
      "body_template": {
        "title": "{title}"
      },
      "parameters": {
        "title": {
          "type": "string",
          "required": true,
          "description": "Document title"
        }
      },
      "success_extract": "$.documentId",
      "success_message": "Document created: {result}"
    },
    "append_text": {
      "display_name": "Append text to Doc",
      "description": "Insert text at the beginning of an existing Google Docs document",
      "endpoint": "https://docs.googleapis.com/v1/documents/{document_id}:batchUpdate",
      "method": "POST",
      "headers": {
        "Content-Type": "application/json"
      },
      "body_template": {
        "requests": [
          {
            "insertText": {
              "location": {
                "index": 1
              },
              "text": "{text}"
            }
          }
        ]
      },
      "parameters": {
        "document_id": {
          "type": "string",
          "required": true,
          "description": "The Google Docs document ID"
        },
        "text": {
          "type": "string",
          "required": true,
          "description": "Text to insert into the document"
        }
      },
      "success_message": "Text appended to document"
    },
    "read_document": {
      "display_name": "Read Google Doc",
      "description": "Read the title and content of a Google Docs document",
      "endpoint": "https://docs.googleapis.com/v1/documents/{document_id}",
      "method": "GET",
      "parameters": {
        "document_id": {
          "type": "string",
          "required": true,
          "description": "The Google Docs document ID"
        }
      },
      "success_extract": "$.title",
      "success_message": "Document: {result}"
    }
  },
  "workflows": {
    "create-event": "create_event",
    "write-email": "send_email"
  },
  "claude_context": {
    "defaults": {}
  }
}
